#include <stdio.h>

// Inner structure
struct Address {
    char city[50];
    int pincode;
};

// Outer structure (nested structure)
struct Student {
    int id;
    char name[50];
    struct Address addr;  // Nested structure
};

int main() {
    // Declare structure variable
    struct Student s1;

    // Assign values
    s1.id = 101;
    sprintf(s1.name, "Komi");
    
    // Access nested structure members
    sprintf(s1.addr.city, "Hyderabad");
    s1.addr.pincode = 500001;

    // Display values
    printf("Student ID: %d\n", s1.id);
    printf("Student Name: %s\n", s1.name);
    printf("City: %s\n", s1.addr.city);
    printf("Pincode: %d\n", s1.addr.pincode);

    return 0;
}
